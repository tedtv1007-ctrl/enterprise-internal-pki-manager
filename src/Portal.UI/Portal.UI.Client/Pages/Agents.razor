@page "/agents"
@using Portal.UI.Client.Services
@using EnterprisePKI.Shared.Models
@inject PkiApiClient ApiClient
@rendermode InteractiveAuto

<PageTitle>Agent Management</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="16" Width="100%">
    <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" VerticalAlignment="VerticalAlignment.Center" Width="100%">
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="12">
            <FluentIcon Value="@(new Icons.Regular.Size28.Desktop())" Color="Color.Success" />
            <FluentLabel Typo="Typography.PageTitle">Agent Management</FluentLabel>
        </FluentStack>
        @if (agents != null)
        {
            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="8">
                <FluentBadge Appearance="Appearance.Accent">@agents.Count(a => IsOnline(a)) online</FluentBadge>
                <FluentLabel Typo="Typography.Body" Style="opacity: 0.6;">/ @agents.Count total</FluentLabel>
            </FluentStack>
        }
    </FluentStack>

    @if (agents == null)
    {
        <FluentProgress />
    }
    else if (!agents.Any())
    {
        <FluentCard Style="padding: 3rem; text-align: center;">
            <FluentIcon Value="@(new Icons.Regular.Size24.Desktop())" />
            <FluentLabel Typo="Typography.Body" Style="display: block; margin-top: 1rem; opacity: 0.6;">No agents detected. Deploy a Collector to start discovering certificates.</FluentLabel>
            <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size16.ArrowDownload())" Style="margin-top: 1rem;">Download Collector Agent</FluentButton>
        </FluentCard>
    }
    else
    {
        <FluentGrid Spacing="3" Justify="JustifyContent.FlexStart">
            @foreach (var agent in agents)
            {
                var isOnline = IsOnline(agent);
                <FluentGridItem xs="12" sm="6" lg="4">
                    <FluentCard Style="padding: 1.25rem; height: 100%;">
                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="12" Style="height: 100%;">
                            <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" VerticalAlignment="VerticalAlignment.Top">
                                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="10">
                                    <FluentIcon Value="@GetAgentIcon(agent.Type)" />
                                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="2">
                                        <FluentLabel Typo="Typography.Body" Style="font-weight: 600;">@agent.Hostname</FluentLabel>
                                        <FluentLabel Typo="Typography.Body" Style="font-size: 0.8rem; opacity: 0.6;">@agent.Type Agent</FluentLabel>
                                    </FluentStack>
                                </FluentStack>
                                <FluentBadge Appearance="@(isOnline ? Appearance.Accent : Appearance.Neutral)" 
                                             BackgroundColor="@(isOnline ? "var(--success)" : "var(--error)")">
                                    @(isOnline ? "ONLINE" : "OFFLINE")
                                </FluentBadge>
                            </FluentStack>

                            <FluentStack Orientation="Orientation.Vertical" VerticalGap="8" Style="font-size: 0.85rem;">
                                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween">
                                    <FluentLabel Typo="Typography.Body" Style="opacity: 0.6;">IP Address</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Style="font-family: monospace;">@(agent.IPAddress ?? "—")</FluentLabel>
                                </FluentStack>
                                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween">
                                    <FluentLabel Typo="Typography.Body" Style="opacity: 0.6;">Last Heartbeat</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Style="@(isOnline ? "color: var(--success);" : "color: var(--error);")">
                                        @FormatHeartbeat(agent.LastHeartbeat)
                                    </FluentLabel>
                                </FluentStack>
                            </FluentStack>

                            <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.End" HorizontalGap="8" Style="margin-top: auto; padding-top: 0.5rem;">
                                <FluentButton Appearance="Appearance.Outline" IconStart="@(new Icons.Regular.Size16.Window())">Logs</FluentButton>
                                <FluentButton Appearance="Appearance.Outline" IconStart="@(new Icons.Regular.Size16.ArrowSync())">Restart</FluentButton>
                            </FluentStack>
                        </FluentStack>
                    </FluentCard>
                </FluentGridItem>
            }
        </FluentGrid>
    }
</FluentStack>

@code {
    private List<Agent>? agents;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            agents = await ApiClient.GetAgentsAsync();
        }
        catch (Exception)
        {
            agents = new List<Agent>
            {
                new Agent { Hostname = "WIN-COLLECTOR-01", IPAddress = "10.0.5.120", Type = "Windows", LastHeartbeat = DateTime.UtcNow.AddSeconds(-45), Status = "Online" },
                new Agent { Hostname = "LINUX-NODE-04", IPAddress = "10.0.5.142", Type = "Linux", LastHeartbeat = DateTime.UtcNow.AddMinutes(-12), Status = "Offline" },
                new Agent { Hostname = "WIN-IIS-PROD-02", IPAddress = "10.0.10.55", Type = "Windows", LastHeartbeat = DateTime.UtcNow.AddMinutes(-2), Status = "Online" },
                new Agent { Hostname = "K8S-WORKER-07", IPAddress = "10.0.20.77", Type = "Linux", LastHeartbeat = DateTime.UtcNow.AddMinutes(-1), Status = "Online" },
                new Agent { Hostname = "F5-LB-EDGE-01", IPAddress = "10.0.1.10", Type = "F5", LastHeartbeat = DateTime.UtcNow.AddSeconds(-45), Status = "Online" }
            };
        }
    }

    private bool IsOnline(Agent agent) =>
        agent.LastHeartbeat.HasValue && agent.LastHeartbeat > DateTime.UtcNow.AddMinutes(-5);

    private string FormatHeartbeat(DateTime? heartbeat)
    {
        if (!heartbeat.HasValue) return "Never";
        var diff = DateTime.UtcNow - heartbeat.Value;
        if (diff.TotalSeconds < 60) return $"{(int)diff.TotalSeconds}s ago";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        return $"{(int)diff.TotalHours}h ago";
    }

    private Icon GetAgentIcon(string type) => type switch
    {
        "Windows" => new Icons.Regular.Size24.Window(),
        "Linux" => new Icons.Regular.Size24.Server(),
        "F5" => new Icons.Regular.Size24.Server(),
        _ => new Icons.Regular.Size24.Server()
    };
}
