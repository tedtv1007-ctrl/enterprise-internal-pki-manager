@page "/agents"
@using Portal.UI.Client.Services
@using EnterprisePKI.Shared.Models
@inject PkiApiClient ApiClient
@rendermode InteractiveAuto

<PageTitle>Agent Management</PageTitle>

<div class="container-fluid">
    <div class="page-header">
        <h1>
            <div class="header-icon" style="background: rgba(52, 211, 153, 0.1); color: var(--accent-emerald);">
                <i class="bi bi-cpu-fill"></i>
            </div>
            Agent Management
        </h1>
        <div class="d-flex align-items-center gap-3">
            @if (agents != null)
            {
                <span class="small" style="color: var(--text-muted);">
                    <span style="color: var(--accent-emerald); font-weight: 600;">@agents.Count(a => IsOnline(a))</span> online /
                    <span>@agents.Count total</span>
                </span>
            }
        </div>
    </div>

    <div class="row g-3">
        @if (agents == null)
        {
            <div class="col-12 text-center py-5"><div class="spinner-border"></div></div>
        }
        else if (!agents.Any())
        {
            <div class="col-12">
                <div class="card">
                    <div class="card-body text-center py-5">
                        <i class="bi bi-cpu" style="font-size: 2.5rem; color: var(--text-muted);"></i>
                        <p class="mt-3 text-muted">No agents detected. Deploy a Collector to start discovering certificates.</p>
                        <button class="btn btn-primary"><i class="bi bi-download"></i> Download Collector Agent</button>
                    </div>
                </div>
            </div>
        }
        else
        {
            @for (int i = 0; i < agents.Count; i++)
            {
                var agent = agents[i];
                var isOnline = IsOnline(agent);
                <div class="col-md-6 col-xl-4 fade-in" style="animation-delay: @(i * 0.05)s;">
                    <div class="card h-100" style="@(isOnline ? "border-color: rgba(52, 211, 153, 0.2);" : "")">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width: 40px; height: 40px; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; background: @GetTypeColor(agent.Type); font-size: 1.1rem;">
                                        <i class="bi @GetTypeIcon(agent.Type)"></i>
                                    </div>
                                    <div>
                                        <div class="fw-semibold">@agent.Hostname</div>
                                        <div class="small text-muted">@agent.Type Agent</div>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="pulse-dot @(isOnline ? "online" : "offline")"></span>
                                    <span class="badge @(isOnline ? "bg-success" : "bg-danger")" style="font-size: 0.65rem;">
                                        @(isOnline ? "ONLINE" : "OFFLINE")
                                    </span>
                                </div>
                            </div>
                            <div class="d-flex flex-column gap-2" style="font-size: 0.8rem;">
                                <div class="d-flex justify-content-between">
                                    <span class="text-muted"><i class="bi bi-hdd-network me-1"></i> IP Address</span>
                                    <span class="font-monospace" style="color: var(--text-secondary);">@(agent.IPAddress ?? "—")</span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span class="text-muted"><i class="bi bi-clock me-1"></i> Last Heartbeat</span>
                                    <span style="color: @(isOnline ? "var(--accent-emerald)" : "var(--accent-rose)");">
                                        @FormatHeartbeat(agent.LastHeartbeat)
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer d-flex justify-content-end gap-2">
                            <button class="btn btn-sm btn-outline-light"><i class="bi bi-terminal"></i> Logs</button>
                            <button class="btn btn-sm btn-outline-warning"><i class="bi bi-arrow-repeat"></i> Restart</button>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<Agent>? agents;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            agents = await ApiClient.GetAgentsAsync();
        }
        catch (Exception)
        {
            agents = new List<Agent>
            {
                new Agent { Hostname = "WIN-COLLECTOR-01", IPAddress = "10.0.5.120", Type = "Windows", LastHeartbeat = DateTime.UtcNow.AddSeconds(-45), Status = "Online" },
                new Agent { Hostname = "LINUX-NODE-04", IPAddress = "10.0.5.142", Type = "Linux", LastHeartbeat = DateTime.UtcNow.AddMinutes(-12), Status = "Offline" },
                new Agent { Hostname = "WIN-IIS-PROD-02", IPAddress = "10.0.10.55", Type = "Windows", LastHeartbeat = DateTime.UtcNow.AddMinutes(-2), Status = "Online" },
                new Agent { Hostname = "K8S-WORKER-07", IPAddress = "10.0.20.77", Type = "Linux", LastHeartbeat = DateTime.UtcNow.AddMinutes(-1), Status = "Online" },
                new Agent { Hostname = "F5-LB-EDGE-01", IPAddress = "10.0.1.10", Type = "F5", LastHeartbeat = DateTime.UtcNow.AddSeconds(-45), Status = "Online" }
            };
        }
    }

    private bool IsOnline(Agent agent) =>
        agent.LastHeartbeat.HasValue && agent.LastHeartbeat > DateTime.UtcNow.AddMinutes(-5);

    private string FormatHeartbeat(DateTime? heartbeat)
    {
        if (!heartbeat.HasValue) return "Never";
        var diff = DateTime.UtcNow - heartbeat.Value;
        if (diff.TotalSeconds < 60) return $"{(int)diff.TotalSeconds}s ago";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        return $"{(int)diff.TotalHours}h ago";
    }

    private string GetTypeIcon(string type) => type switch
    {
        "Windows" => "bi-windows",
        "Linux" => "bi-ubuntu",
        "F5" => "bi-hdd-rack",
        _ => "bi-server"
    };

    private string GetTypeColor(string type) => type switch
    {
        "Windows" => "rgba(96, 165, 250, 0.1)",
        "Linux" => "rgba(251, 191, 36, 0.1)",
        "F5" => "rgba(167, 139, 250, 0.1)",
        _ => "rgba(148, 163, 184, 0.1)"
    };
}
