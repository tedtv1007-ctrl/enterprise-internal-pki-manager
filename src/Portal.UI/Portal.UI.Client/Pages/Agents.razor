@page "/agents"
@using Portal.UI.Client.Services
@using EnterprisePKI.Shared.Models
@inject PkiApiClient ApiClient
@rendermode InteractiveAuto

<PageTitle>Agent Management</PageTitle>

<RadzenStack Gap="1rem" Style="width: 100%;">
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Style="width: 100%;">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
            <RadzenIcon Icon="computer" Style="color: var(--rz-success);" />
            <RadzenText TextStyle="TextStyle.H4" Style="margin: 0;">Agent Management</RadzenText>
        </RadzenStack>
        @if (agents != null)
        {
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenBadge Text="@($"{agents.Count(a => IsOnline(a))} online")" BadgeStyle="BadgeStyle.Success" />
                <span style="opacity: 0.6;">/ @agents.Count total</span>
            </RadzenStack>
        }
    </RadzenStack>

    @if (agents == null)
    {
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    }
    else if (!agents.Any())
    {
        <RadzenCard Style="padding: 3rem; text-align: center;">
            <RadzenIcon Icon="computer" />
            <RadzenText TextStyle="TextStyle.Body1" Style="display: block; margin-top: 1rem; opacity: 0.6;">No agents detected. Deploy a Collector to start discovering certificates.</RadzenText>
            <RadzenButton Text="Download Collector Agent" Icon="download" ButtonStyle="ButtonStyle.Primary" Style="margin-top: 1rem;" />
        </RadzenCard>
    }
    else
    {
        <RadzenRow Gap="1rem">
            @foreach (var agent in agents)
            {
                var isOnline = IsOnline(agent);
                <RadzenColumn SizeSM="6" SizeLG="4">
                    <RadzenCard Style="padding: 1.25rem; height: 100%;">
                        <RadzenStack Gap="0.75rem" Style="height: 100%;">
                            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.625rem">
                                    <RadzenIcon Icon="@GetAgentIcon(agent.Type)" />
                                    <RadzenStack Gap="0.125rem">
                                        <span style="font-weight: 600;">@agent.Hostname</span>
                                        <span style="font-size: 0.8rem; opacity: 0.6;">@agent.Type Agent</span>
                                    </RadzenStack>
                                </RadzenStack>
                                <RadzenBadge Text="@(isOnline ? "ONLINE" : "OFFLINE")" 
                                             BadgeStyle="@(isOnline ? BadgeStyle.Success : BadgeStyle.Danger)" />
                            </RadzenStack>

                            <RadzenStack Gap="0.5rem" Style="font-size: 0.85rem;">
                                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween">
                                    <span style="opacity: 0.6;">IP Address</span>
                                    <span style="font-family: monospace;">@(agent.IPAddress ?? "—")</span>
                                </RadzenStack>
                                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween">
                                    <span style="opacity: 0.6;">Last Heartbeat</span>
                                    <span style="@(isOnline ? "color: var(--rz-success);" : "color: var(--rz-danger);")">
                                        @FormatHeartbeat(agent.LastHeartbeat)
                                    </span>
                                </RadzenStack>
                            </RadzenStack>

                            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem" Style="margin-top: auto; padding-top: 0.5rem;">
                                <RadzenButton Text="Logs" Icon="description" ButtonStyle="ButtonStyle.Light" />
                                <RadzenButton Text="Restart" Icon="sync" ButtonStyle="ButtonStyle.Light" />
                            </RadzenStack>
                        </RadzenStack>
                    </RadzenCard>
                </RadzenColumn>
            }
        </RadzenRow>
    }
</RadzenStack>

@code {
    private List<Agent>? agents;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            agents = await ApiClient.GetAgentsAsync();
        }
        catch (Exception)
        {
            agents = new List<Agent>
            {
                new Agent { Hostname = "WIN-COLLECTOR-01", IPAddress = "10.0.5.120", Type = "Windows", LastHeartbeat = DateTime.UtcNow.AddSeconds(-45), Status = "Online" },
                new Agent { Hostname = "LINUX-NODE-04", IPAddress = "10.0.5.142", Type = "Linux", LastHeartbeat = DateTime.UtcNow.AddMinutes(-12), Status = "Offline" },
                new Agent { Hostname = "WIN-IIS-PROD-02", IPAddress = "10.0.10.55", Type = "Windows", LastHeartbeat = DateTime.UtcNow.AddMinutes(-2), Status = "Online" },
                new Agent { Hostname = "K8S-WORKER-07", IPAddress = "10.0.20.77", Type = "Linux", LastHeartbeat = DateTime.UtcNow.AddMinutes(-1), Status = "Online" },
                new Agent { Hostname = "F5-LB-EDGE-01", IPAddress = "10.0.1.10", Type = "F5", LastHeartbeat = DateTime.UtcNow.AddSeconds(-45), Status = "Online" }
            };
        }
    }

    private bool IsOnline(Agent agent) =>
        agent.LastHeartbeat.HasValue && agent.LastHeartbeat > DateTime.UtcNow.AddMinutes(-5);

    private string FormatHeartbeat(DateTime? heartbeat)
    {
        if (!heartbeat.HasValue) return "Never";
        var diff = DateTime.UtcNow - heartbeat.Value;
        if (diff.TotalSeconds < 60) return $"{(int)diff.TotalSeconds}s ago";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        return $"{(int)diff.TotalHours}h ago";
    }

    private string GetAgentIcon(string type) => type switch
    {
        "Windows" => "desktop_windows",
        "Linux" => "dns",
        "F5" => "storage",
        _ => "dns"
    };
}
