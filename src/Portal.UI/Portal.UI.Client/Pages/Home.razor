@page "/"
@using Portal.UI.Client.Services
@inject PkiApiClient ApiClient
@rendermode InteractiveAuto

<PageTitle>PKI Overview</PageTitle>

<RadzenStack Gap="1rem" Style="width: 100%;">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
        <RadzenIcon Icon="dashboard" Style="color: var(--rz-primary);" />
        <RadzenText TextStyle="TextStyle.H4" Style="margin: 0;">Dashboard</RadzenText>
        <RadzenBadge Text="PQC READY" BadgeStyle="BadgeStyle.Info" />
    </RadzenStack>

    @if (stats == null)
    {
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    }
    else
    {
        <!-- Stat Cards -->
        <RadzenRow Gap="1rem">
            <RadzenColumn SizeSM="6" SizeLG="3">
                <RadzenCard Style="padding: 1.25rem;">
                    <RadzenStack Gap="0.5rem">
                        <RadzenIcon Icon="lock" Style="color: var(--rz-primary);" />
                        <RadzenText TextStyle="TextStyle.Overline" Style="opacity: 0.7;">Total Certificates</RadzenText>
                        <RadzenText TextStyle="TextStyle.H3" Style="margin: 0;">@stats.TotalCertificates</RadzenText>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn SizeSM="6" SizeLG="3">
                <RadzenCard Style="padding: 1.25rem;">
                    <RadzenStack Gap="0.5rem">
                        <RadzenIcon Icon="warning" Style="color: var(--rz-warning);" />
                        <RadzenText TextStyle="TextStyle.Overline" Style="opacity: 0.7;">Expiring Soon (30d)</RadzenText>
                        <RadzenText TextStyle="TextStyle.H3" Style="margin: 0; color: var(--rz-warning);">@stats.ExpiringSoon</RadzenText>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn SizeSM="6" SizeLG="3">
                <RadzenCard Style="padding: 1.25rem;">
                    <RadzenStack Gap="0.5rem">
                        <RadzenIcon Icon="computer" Style="color: var(--rz-success);" />
                        <RadzenText TextStyle="TextStyle.Overline" Style="opacity: 0.7;">Active Agents</RadzenText>
                        <RadzenText TextStyle="TextStyle.H3" Style="margin: 0; color: var(--rz-success);">@stats.ActiveAgents</RadzenText>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn SizeSM="6" SizeLG="3">
                <RadzenCard Style="padding: 1.25rem;">
                    <RadzenStack Gap="0.5rem">
                        <RadzenIcon Icon="verified_user" />
                        <RadzenText TextStyle="TextStyle.Overline" Style="opacity: 0.7;">PQC-Ready Certs</RadzenText>
                        <RadzenText TextStyle="TextStyle.H3" Style="margin: 0;">@stats.PqcReadyCertificates</RadzenText>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
        </RadzenRow>

        <!-- Bottom Section -->
        <RadzenRow Gap="1rem">
            <RadzenColumn SizeLG="8">
                <RadzenCard Style="padding: 1.25rem;">
                    <RadzenStack Gap="1rem">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <RadzenIcon Icon="monitor_heart" Style="color: var(--rz-primary);" />
                            <RadzenText TextStyle="TextStyle.H6" Style="font-weight: 600; margin: 0;">System Health</RadzenText>
                        </RadzenStack>

                        <RadzenStack Gap="0.75rem">
                            <div>
                                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                                    <RadzenText TextStyle="TextStyle.Body1" Style="margin: 0;">Certificate Coverage</RadzenText>
                                    <RadzenText TextStyle="TextStyle.Body1" Style="font-weight: 600; color: var(--rz-success); margin: 0;">92%</RadzenText>
                                </RadzenStack>
                                <RadzenProgressBar Value="92" Max="100" ShowValue="false" Style="height: 8px;" />
                            </div>
                            <div>
                                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                                    <RadzenText TextStyle="TextStyle.Body1" Style="margin: 0;">Agent Connectivity</RadzenText>
                                    <RadzenText TextStyle="TextStyle.Body1" Style="font-weight: 600; color: var(--rz-primary); margin: 0;">80%</RadzenText>
                                </RadzenStack>
                                <RadzenProgressBar Value="80" Max="100" ShowValue="false" Style="height: 8px;" />
                            </div>
                            <div>
                                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                                    <RadzenText TextStyle="TextStyle.Body1" Style="margin: 0;">PQC Migration Progress</RadzenText>
                                    <RadzenText TextStyle="TextStyle.Body1" Style="font-weight: 600; margin: 0;">@(stats.TotalCertificates > 0 ? (stats.PqcReadyCertificates * 100 / stats.TotalCertificates) : 0)%</RadzenText>
                                </RadzenStack>
                                <RadzenProgressBar Value="@(stats.TotalCertificates > 0 ? (stats.PqcReadyCertificates * 100 / stats.TotalCertificates) : 0)" Max="100" ShowValue="false" Style="height: 8px;" />
                            </div>
                            <div>
                                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                                    <RadzenText TextStyle="TextStyle.Body1" Style="margin: 0;">Deployment Success Rate</RadzenText>
                                    <RadzenText TextStyle="TextStyle.Body1" Style="font-weight: 600; color: var(--rz-warning); margin: 0;">88%</RadzenText>
                                </RadzenStack>
                                <RadzenProgressBar Value="88" Max="100" ShowValue="false" Style="height: 8px;" />
                            </div>
                        </RadzenStack>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn SizeLG="4">
                <RadzenCard Style="padding: 1.25rem; height: 100%;">
                    <RadzenStack Gap="0.75rem" Style="height: 100%;">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <RadzenIcon Icon="bolt" Style="color: var(--rz-warning);" />
                            <RadzenText TextStyle="TextStyle.H6" Style="font-weight: 600; margin: 0;">Quick Actions</RadzenText>
                        </RadzenStack>

                        <a href="/certificates" class="quick-action-link rz-button rz-button-md rz-variant-filled rz-primary" style="width: 100%; text-align: center; text-decoration: none;">
                            Request New Certificate
                        </a>
                        <a href="/deployments" class="quick-action-link rz-button rz-button-md rz-variant-outlined rz-primary" style="width: 100%; text-align: center; text-decoration: none;">
                            Manage Deployments
                        </a>
                        <a href="/agents" class="quick-action-link rz-button rz-button-md rz-variant-outlined rz-primary" style="width: 100%; text-align: center; text-decoration: none;">
                            View Agents
                        </a>

                        <div style="margin-top: auto; padding-top: 1rem;">
                            <RadzenText TextStyle="TextStyle.Caption" Style="opacity: 0.5;">
                                Last scan: 2 minutes ago
                            </RadzenText>
                        </div>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
        </RadzenRow>
    }
</RadzenStack>

@code {
    private DashboardStats? stats;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            stats = await ApiClient.GetStatsAsync();
        }
        catch (Exception ex)
        {
            stats = new DashboardStats { TotalCertificates = 8, ExpiringSoon = 2, ActiveAgents = 4, PqcReadyCertificates = 3 };
        }
    }
}
