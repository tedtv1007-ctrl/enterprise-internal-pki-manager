@page "/"
@using Portal.UI.Client.Services
@inject PkiApiClient ApiClient
@rendermode InteractiveAuto

<PageTitle>PKI Overview</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="16" Width="100%">
    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="12">
        <FluentIcon Value="@(new Icons.Regular.Size28.Grid())" Color="Color.Accent" />
        <FluentLabel Typo="Typography.PageTitle">Dashboard</FluentLabel>
        <FluentBadge Appearance="Appearance.Accent">PQC READY</FluentBadge>
    </FluentStack>

    @if (stats == null)
    {
        <FluentProgress />
    }
    else
    {
        <!-- Stat Cards -->
        <FluentGrid Spacing="3" Justify="JustifyContent.FlexStart">
            <FluentGridItem xs="12" sm="6" md="6" lg="3">
                <FluentCard Style="padding: 1.25rem;">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                        <FluentIcon Value="@(new Icons.Regular.Size24.DocumentLock())" Color="Color.Accent" />
                        <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em;">Total Certificates</FluentLabel>
                        <FluentLabel Typo="Typography.PageTitle">@stats.TotalCertificates</FluentLabel>
                    </FluentStack>
                </FluentCard>
            </FluentGridItem>
            <FluentGridItem xs="12" sm="6" md="6" lg="3">
                <FluentCard Style="padding: 1.25rem;">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                        <FluentIcon Value="@(new Icons.Regular.Size24.Warning())" Color="Color.Warning" />
                        <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em;">Expiring Soon (30d)</FluentLabel>
                        <FluentLabel Typo="Typography.PageTitle" Style="color: var(--warning);">@stats.ExpiringSoon</FluentLabel>
                    </FluentStack>
                </FluentCard>
            </FluentGridItem>
            <FluentGridItem xs="12" sm="6" md="6" lg="3">
                <FluentCard Style="padding: 1.25rem;">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                        <FluentIcon Value="@(new Icons.Regular.Size24.Desktop())" Color="Color.Success" />
                        <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em;">Active Agents</FluentLabel>
                        <FluentLabel Typo="Typography.PageTitle" Style="color: var(--success);">@stats.ActiveAgents</FluentLabel>
                    </FluentStack>
                </FluentCard>
            </FluentGridItem>
            <FluentGridItem xs="12" sm="6" md="6" lg="3">
                <FluentCard Style="padding: 1.25rem;">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                        <FluentIcon Value="@(new Icons.Regular.Size24.ShieldCheckmark())" />
                        <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em;">PQC-Ready Certs</FluentLabel>
                        <FluentLabel Typo="Typography.PageTitle">@stats.PqcReadyCertificates</FluentLabel>
                    </FluentStack>
                </FluentCard>
            </FluentGridItem>
        </FluentGrid>

        <!-- Bottom Section -->
        <FluentGrid Spacing="3">
            <FluentGridItem xs="12" lg="8">
                <FluentCard Style="padding: 1.25rem;">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="8">
                            <FluentIcon Value="@(new Icons.Regular.Size20.Pulse())" Color="Color.Accent" />
                            <FluentLabel Typo="Typography.Subject" Style="font-weight: 600;">System Health</FluentLabel>
                        </FluentStack>

                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
                            <div>
                                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween">
                                    <FluentLabel Typo="Typography.Body">Certificate Coverage</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Style="font-weight: 600; color: var(--success);">92%</FluentLabel>
                                </FluentStack>
                                <FluentProgress Min="0" Max="100" Value="92" />
                            </div>
                            <div>
                                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween">
                                    <FluentLabel Typo="Typography.Body">Agent Connectivity</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Style="font-weight: 600; color: var(--accent-fill-rest);">80%</FluentLabel>
                                </FluentStack>
                                <FluentProgress Min="0" Max="100" Value="80" />
                            </div>
                            <div>
                                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween">
                                    <FluentLabel Typo="Typography.Body">PQC Migration Progress</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Style="font-weight: 600;">@(stats.TotalCertificates > 0 ? (stats.PqcReadyCertificates * 100 / stats.TotalCertificates) : 0)%</FluentLabel>
                                </FluentStack>
                                <FluentProgress Min="0" Max="100" Value="@(stats.TotalCertificates > 0 ? (stats.PqcReadyCertificates * 100 / stats.TotalCertificates) : 0)" />
                            </div>
                            <div>
                                <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween">
                                    <FluentLabel Typo="Typography.Body">Deployment Success Rate</FluentLabel>
                                    <FluentLabel Typo="Typography.Body" Style="font-weight: 600; color: var(--warning);">88%</FluentLabel>
                                </FluentStack>
                                <FluentProgress Min="0" Max="100" Value="88" />
                            </div>
                        </FluentStack>
                    </FluentStack>
                </FluentCard>
            </FluentGridItem>
            <FluentGridItem xs="12" lg="4">
                <FluentCard Style="padding: 1.25rem; height: 100%;">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="12" Style="height: 100%;">
                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="8">
                            <FluentIcon Value="@(new Icons.Regular.Size20.Flash())" Color="Color.Warning" />
                            <FluentLabel Typo="Typography.Subject" Style="font-weight: 600;">Quick Actions</FluentLabel>
                        </FluentStack>

                        <FluentAnchor Href="/certificates" Appearance="Appearance.Accent" Style="width: 100%;">
                            Request New Certificate
                        </FluentAnchor>
                        <FluentAnchor Href="/deployments" Appearance="Appearance.Outline" Style="width: 100%;">
                            Manage Deployments
                        </FluentAnchor>
                        <FluentAnchor Href="/agents" Appearance="Appearance.Outline" Style="width: 100%;">
                            View Agents
                        </FluentAnchor>

                        <div style="margin-top: auto; padding-top: 1rem;">
                            <FluentLabel Typo="Typography.Body" Style="opacity: 0.5;">
                                Last scan: 2 minutes ago
                            </FluentLabel>
                        </div>
                    </FluentStack>
                </FluentCard>
            </FluentGridItem>
        </FluentGrid>
    }
</FluentStack>

@code {
    private DashboardStats? stats;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            stats = await ApiClient.GetStatsAsync();
        }
        catch (Exception ex)
        {
            stats = new DashboardStats { TotalCertificates = 8, ExpiringSoon = 2, ActiveAgents = 4, PqcReadyCertificates = 3 };
        }
    }
}
