@page "/certificates"
@using Portal.UI.Client.Services
@using EnterprisePKI.Shared.Models
@inject PkiApiClient ApiClient
@inject Radzen.DialogService DialogService
@inject Radzen.NotificationService NotificationService
@rendermode InteractiveAuto

<PageTitle>Certificate Inventory</PageTitle>

<RadzenStack Gap="1rem" Style="width: 100%;">
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Style="width: 100%;">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
            <RadzenIcon Icon="lock" Style="color: var(--rz-primary);" />
            <RadzenText TextStyle="TextStyle.H4" Style="margin: 0;">Certificate Inventory</RadzenText>
        </RadzenStack>
        <RadzenButton data-testid="request-new-cert-btn" Text="Request New Cert" Icon="add" ButtonStyle="ButtonStyle.Primary" Click="@ShowRequestDialog" />
    </RadzenStack>

    <RadzenCard Style="padding: 0;">
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Style="padding: 1rem;">
            <RadzenText TextStyle="TextStyle.Body1" Style="margin: 0;">@(filteredCertificates?.Count() ?? 0) certificates</RadzenText>
            <RadzenTextBox @bind-Value="searchTerm" Placeholder="Search CN, Thumbprint..." Style="max-width: 320px;" Change="@OnSearchChanged" />
        </RadzenStack>

        @if (filteredCertificates == null)
        {
            <div style="padding: 2rem; text-align: center;">
                <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
            </div>
        }
        else if (!filteredCertificates.Any())
        {
            <div style="padding: 3rem; text-align: center;">
                <RadzenIcon Icon="mail_outline" />
                <RadzenText TextStyle="TextStyle.Body1" Style="display: block; margin-top: 1rem; opacity: 0.6;">No certificates found.</RadzenText>
            </div>
        }
        else
        {
            <RadzenDataGrid Data="@filteredCertificates" TItem="Certificate" AllowSorting="true" Style="width: 100%;">
                <Columns>
                    <RadzenDataGridColumn TItem="Certificate" Title="Common Name" Width="200px">
                        <Template Context="cert">
                            <RadzenStack Gap="0.125rem">
                                <RadzenText TextStyle="TextStyle.Body1" Style="font-weight: 600; margin: 0;">@cert.CommonName</RadzenText>
                                <RadzenText TextStyle="TextStyle.Caption" Style="opacity: 0.5; font-family: monospace; margin: 0;">@TruncateThumbprint(cert.Thumbprint)</RadzenText>
                            </RadzenStack>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Certificate" Title="Status" Width="100px">
                        <Template Context="cert">
                            <RadzenBadge Text="@cert.Status" BadgeStyle="@GetStatusBadgeStyle(cert)" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Certificate" Property="Algorithm" Title="Algorithm" Width="100px" />
                    <RadzenDataGridColumn TItem="Certificate" Property="KeySize" Title="Key Size" Width="90px" />
                    <RadzenDataGridColumn TItem="Certificate" Title="Expiration" Width="160px">
                        <Template Context="cert">
                            @{
                                var daysLeft = (cert.NotAfter - DateTime.UtcNow).Days;
                            }
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                <span style="@GetExpirationStyle(daysLeft)">@cert.NotAfter.ToString("yyyy-MM-dd")</span>
                                @if (daysLeft < 0)
                                {
                                    <RadzenBadge Text="EXPIRED" BadgeStyle="BadgeStyle.Danger" />
                                }
                                else if (daysLeft <= 30)
                                {
                                    <RadzenBadge Text="@($"{daysLeft} d")" BadgeStyle="BadgeStyle.Warning" />
                                }
                            </RadzenStack>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Certificate" Title="PQC" Width="80px">
                        <Template Context="cert">
                            @if (cert.IsPQC)
                            {
                                <RadzenBadge Text="PQC" BadgeStyle="BadgeStyle.Info" />
                            }
                            else
                            {
                                <span style="opacity: 0.5;">Legacy</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Certificate" Title="Actions" Width="140px">
                        <Template Context="cert">
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem">
                                <RadzenButton Icon="visibility" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" title="View Details" />
                                <RadzenButton Icon="rocket_launch" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" title="Deploy" />
                                <RadzenButton Icon="sync" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" title="Renew" />
                            </RadzenStack>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        }
    </RadzenCard>
</RadzenStack>

@code {
    private List<Certificate>? certificates;
    private string searchTerm = "";

    private IEnumerable<Certificate>? filteredCertificates =>
        certificates?.Where(c => string.IsNullOrWhiteSpace(searchTerm) ||
                                 c.CommonName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                                 c.Thumbprint.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            certificates = await ApiClient.GetCertificatesAsync();
        }
        catch (Exception)
        {
            certificates = new List<Certificate>
            {
                new Certificate { CommonName = "*.internal.enterprise.com", Status = "Active", Algorithm = "RSA", KeySize = 4096, NotAfter = DateTime.UtcNow.AddYears(1), Thumbprint = "A1B2C3D4E5F6G7H8I9J0K1L2M3N4O5P6Q7R8S9T0", IsPQC = false },
                new Certificate { CommonName = "vault.internal.enterprise.com", Status = "Active", Algorithm = "ML-KEM-768", KeySize = 3168, NotAfter = DateTime.UtcNow.AddMonths(6), Thumbprint = "PQC-DILITHIUM3-ABCDEF1234567890", IsPQC = true },
                new Certificate { CommonName = "legacy-app.internal", Status = "Active", Algorithm = "RSA", KeySize = 2048, NotAfter = DateTime.UtcNow.AddDays(15), Thumbprint = "Z9Y8X7W6V5U4T3S2R1Q0P9O8N7M6L5K4", IsPQC = false },
                new Certificate { CommonName = "old-intranet.internal", Status = "Expired", Algorithm = "RSA", KeySize = 1024, NotAfter = DateTime.UtcNow.AddDays(-5), Thumbprint = "E5F6A7B8C9D0E1F2A3B4C5D6E7F8A9B0", IsPQC = false }
            };
        }
    }

    private void OnSearchChanged() => StateHasChanged();

    private string TruncateThumbprint(string tp) => tp.Length > 24 ? tp[..24] + "..." : tp;

    private BadgeStyle GetStatusBadgeStyle(Certificate cert) => cert.Status switch
    {
        "Active" => BadgeStyle.Success,
        "Expired" => BadgeStyle.Danger,
        _ => BadgeStyle.Light
    };

    private string GetExpirationStyle(int daysLeft)
    {
        if (daysLeft < 0) return "color: var(--rz-danger); font-weight: 600;";
        if (daysLeft <= 30) return "color: var(--rz-warning);";
        return "";
    }

    private async Task ShowRequestDialog()
    {
        var result = await DialogService.OpenAsync<Portal.UI.Client.Components.Dialogs.CertificateRequestDialog>("Request New Certificate", new Dictionary<string, object>(), new Radzen.DialogOptions { Width = "640px" });
        if (result != null)
        {
            NotificationService.Notify(new Radzen.NotificationMessage
            {
                Severity = Radzen.NotificationSeverity.Success,
                Summary = "Certificate Requested",
                Detail = "Your certificate request has been submitted.",
                Duration = 4000
            });
            // Refresh the certificate list
            try
            {
                certificates = await ApiClient.GetCertificatesAsync();
            }
            catch { }
            StateHasChanged();
        }
    }
}
