@page "/certificates"
@using Portal.UI.Client.Services
@using EnterprisePKI.Shared.Models
@inject PkiApiClient ApiClient
@rendermode InteractiveAuto

<PageTitle>Certificate Inventory</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="16" Width="100%">
    <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" VerticalAlignment="VerticalAlignment.Center" Width="100%">
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="12">
            <FluentIcon Value="@(new Icons.Regular.Size28.DocumentLock())" Color="Color.Accent" />
            <FluentLabel Typo="Typography.PageTitle">Certificate Inventory</FluentLabel>
        </FluentStack>
        <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size16.Add())">Request New Cert</FluentButton>
    </FluentStack>

    <FluentCard Style="padding: 0;">
        <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" VerticalAlignment="VerticalAlignment.Center" Style="padding: 1rem;">
            <FluentLabel Typo="Typography.Body">@(filteredCertificates?.Count() ?? 0) certificates</FluentLabel>
            <FluentSearch @bind-Value="searchTerm" @bind-Value:after="OnSearchChanged" Placeholder="Search CN, Thumbprint..." Style="max-width: 320px;" />
        </FluentStack>

        @if (filteredCertificates == null)
        {
            <div style="padding: 2rem; text-align: center;">
                <FluentProgress />
            </div>
        }
        else if (!filteredCertificates.Any())
        {
            <div style="padding: 3rem; text-align: center;">
                <FluentIcon Value="@(new Icons.Regular.Size24.Mail())" />
                <FluentLabel Typo="Typography.Body" Style="display: block; margin-top: 1rem; opacity: 0.6;">No certificates found.</FluentLabel>
            </div>
        }
        else
        {
            <FluentDataGrid Items="@filteredCertificates" TGridItem="Certificate" Style="width: 100%;" ShowHover="true" GridTemplateColumns="2fr 0.8fr 0.8fr 0.8fr 1.2fr 0.7fr 1fr">
                <TemplateColumn Title="Common Name">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="2">
                        <FluentLabel Typo="Typography.Body" Style="font-weight: 600;">@context.CommonName</FluentLabel>
                        <FluentLabel Typo="Typography.Body" Style="font-size: 0.7rem; opacity: 0.5; font-family: monospace;">@TruncateThumbprint(context.Thumbprint)</FluentLabel>
                    </FluentStack>
                </TemplateColumn>
                <TemplateColumn Title="Status">
                    <FluentBadge Appearance="@GetStatusAppearance(context)">@context.Status</FluentBadge>
                </TemplateColumn>
                <PropertyColumn Property="@(c => c.Algorithm)" Title="Algorithm" />
                <PropertyColumn Property="@(c => c.KeySize)" Title="Key Size" />
                <TemplateColumn Title="Expiration">
                    @{
                        var daysLeft = (context.NotAfter - DateTime.UtcNow).Days;
                    }
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="8">
                        <FluentLabel Typo="Typography.Body" Style="@GetExpirationStyle(daysLeft)">@context.NotAfter.ToString("yyyy-MM-dd")</FluentLabel>
                        @if (daysLeft < 0)
                        {
                            <FluentBadge Appearance="Appearance.Accent" BackgroundColor="var(--error)">EXPIRED</FluentBadge>
                        }
                        else if (daysLeft <= 30)
                        {
                            <FluentBadge Appearance="Appearance.Accent" BackgroundColor="var(--warning)">@daysLeft d</FluentBadge>
                        }
                    </FluentStack>
                </TemplateColumn>
                <TemplateColumn Title="PQC">
                    @if (context.IsPQC)
                    {
                        <FluentBadge Appearance="Appearance.Accent">PQC</FluentBadge>
                    }
                    else
                    {
                        <FluentLabel Typo="Typography.Body" Style="opacity: 0.5;">Legacy</FluentLabel>
                    }
                </TemplateColumn>
                <TemplateColumn Title="Actions">
                    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="4">
                        <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Eye())" Title="View Details" />
                        <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Rocket())" Title="Deploy" />
                        <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.ArrowSync())" Title="Renew" />
                    </FluentStack>
                </TemplateColumn>
            </FluentDataGrid>
        }
    </FluentCard>
</FluentStack>

@code {
    private List<Certificate>? certificates;
    private string searchTerm = "";

    private IQueryable<Certificate>? filteredCertificates =>
        certificates?.Where(c => string.IsNullOrWhiteSpace(searchTerm) ||
                                 c.CommonName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                                 c.Thumbprint.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
                     .AsQueryable();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            certificates = await ApiClient.GetCertificatesAsync();
        }
        catch (Exception)
        {
            certificates = new List<Certificate>
            {
                new Certificate { CommonName = "*.internal.enterprise.com", Status = "Active", Algorithm = "RSA", KeySize = 4096, NotAfter = DateTime.UtcNow.AddYears(1), Thumbprint = "A1B2C3D4E5F6G7H8I9J0K1L2M3N4O5P6Q7R8S9T0", IsPQC = false },
                new Certificate { CommonName = "vault.internal.enterprise.com", Status = "Active", Algorithm = "ML-KEM-768", KeySize = 3168, NotAfter = DateTime.UtcNow.AddMonths(6), Thumbprint = "PQC-DILITHIUM3-ABCDEF1234567890", IsPQC = true },
                new Certificate { CommonName = "legacy-app.internal", Status = "Active", Algorithm = "RSA", KeySize = 2048, NotAfter = DateTime.UtcNow.AddDays(15), Thumbprint = "Z9Y8X7W6V5U4T3S2R1Q0P9O8N7M6L5K4", IsPQC = false },
                new Certificate { CommonName = "old-intranet.internal", Status = "Expired", Algorithm = "RSA", KeySize = 1024, NotAfter = DateTime.UtcNow.AddDays(-5), Thumbprint = "E5F6A7B8C9D0E1F2A3B4C5D6E7F8A9B0", IsPQC = false }
            };
        }
    }

    private void OnSearchChanged() => StateHasChanged();

    private string TruncateThumbprint(string tp) => tp.Length > 24 ? tp[..24] + "..." : tp;

    private Appearance GetStatusAppearance(Certificate cert) => cert.Status switch
    {
        "Active" => Appearance.Accent,
        "Expired" => Appearance.Neutral,
        _ => Appearance.Lightweight
    };

    private string GetExpirationStyle(int daysLeft)
    {
        if (daysLeft < 0) return "color: var(--error); font-weight: 600;";
        if (daysLeft <= 30) return "color: var(--warning);";
        return "";
    }
}
