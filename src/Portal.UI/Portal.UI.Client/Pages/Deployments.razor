@page "/deployments"
@using Portal.UI.Client.Services
@using EnterprisePKI.Shared.Models
@inject PkiApiClient ApiClient
@rendermode InteractiveAuto

<PageTitle>Deployment Center</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="16" Width="100%">
    <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" VerticalAlignment="VerticalAlignment.Center" Width="100%">
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="12">
            <FluentIcon Value="@(new Icons.Regular.Size24.Rocket())" Color="Color.Warning" />
            <FluentLabel Typo="Typography.PageTitle">Deployment Center</FluentLabel>
        </FluentStack>
        <FluentButton Appearance="Appearance.Outline" IconStart="@(new Icons.Regular.Size16.ArrowSync())" @onclick="RefreshJobs">Refresh</FluentButton>
    </FluentStack>

    <!-- Stats Row -->
    @if (jobs != null)
    {
        <FluentGrid Spacing="3" Justify="JustifyContent.FlexStart">
            <FluentGridItem xs="6" md="3">
                <FluentCard Style="padding: 1rem;">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="10">
                        <FluentIcon Value="@(new Icons.Regular.Size24.CheckmarkCircle())" Color="Color.Success" />
                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="2">
                            <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 0.75rem; text-transform: uppercase;">Completed</FluentLabel>
                            <FluentLabel Typo="Typography.Subject" Style="font-weight: 700;">@jobs.Count(j => j.Status == "Completed")</FluentLabel>
                        </FluentStack>
                    </FluentStack>
                </FluentCard>
            </FluentGridItem>
            <FluentGridItem xs="6" md="3">
                <FluentCard Style="padding: 1rem;">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="10">
                        <FluentIcon Value="@(new Icons.Regular.Size24.ArrowSync())" Color="Color.Accent" />
                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="2">
                            <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 0.75rem; text-transform: uppercase;">In Progress</FluentLabel>
                            <FluentLabel Typo="Typography.Subject" Style="font-weight: 700;">@jobs.Count(j => j.Status == "InProgress")</FluentLabel>
                        </FluentStack>
                    </FluentStack>
                </FluentCard>
            </FluentGridItem>
            <FluentGridItem xs="6" md="3">
                <FluentCard Style="padding: 1rem;">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="10">
                        <FluentIcon Value="@(new Icons.Regular.Size24.Clock())" Color="Color.Warning" />
                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="2">
                            <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 0.75rem; text-transform: uppercase;">Pending</FluentLabel>
                            <FluentLabel Typo="Typography.Subject" Style="font-weight: 700;">@jobs.Count(j => j.Status == "Pending")</FluentLabel>
                        </FluentStack>
                    </FluentStack>
                </FluentCard>
            </FluentGridItem>
            <FluentGridItem xs="6" md="3">
                <FluentCard Style="padding: 1rem;">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="10">
                        <FluentIcon Value="@(new Icons.Regular.Size24.DismissCircle())" Color="Color.Error" />
                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="2">
                            <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 0.75rem; text-transform: uppercase;">Failed</FluentLabel>
                            <FluentLabel Typo="Typography.Subject" Style="font-weight: 700;">@jobs.Count(j => j.Status == "Failed")</FluentLabel>
                        </FluentStack>
                    </FluentStack>
                </FluentCard>
            </FluentGridItem>
        </FluentGrid>
    }

    <FluentCard Style="padding: 0;">
        <div style="padding: 1rem;">
            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="8">
                <FluentIcon Value="@(new Icons.Regular.Size20.TaskListSquareLtr())" Color="Color.Warning" />
                <FluentLabel Typo="Typography.Subject" Style="font-weight: 600;">Deployment Jobs</FluentLabel>
            </FluentStack>
        </div>

        @if (jobs == null)
        {
            <div style="padding: 2rem; text-align: center;">
                <FluentProgress />
            </div>
        }
        else if (!jobs.Any())
        {
            <div style="padding: 3rem; text-align: center;">
                <FluentIcon Value="@(new Icons.Regular.Size24.Rocket())" />
                <FluentLabel Typo="Typography.Body" Style="display: block; margin-top: 1rem; opacity: 0.6;">No deployment jobs found.</FluentLabel>
            </div>
        }
        else
        {
            <FluentDataGrid Items="@jobs.AsQueryable()" TGridItem="DeploymentJob" Style="width: 100%;" ShowHover="true" GridTemplateColumns="1fr 1.2fr 1.2fr 1fr 0.8fr 1fr">
                <TemplateColumn Title="Created">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="2">
                        <FluentLabel Typo="Typography.Body">@context.CreatedAt.ToString("yyyy-MM-dd")</FluentLabel>
                        <FluentLabel Typo="Typography.Body" Style="opacity: 0.5; font-size: 0.8rem;">@context.CreatedAt.ToString("HH:mm:ss")</FluentLabel>
                    </FluentStack>
                </TemplateColumn>
                <TemplateColumn Title="Target Host">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="8">
                        <FluentIcon Value="@(new Icons.Regular.Size16.Desktop())" />
                        <FluentLabel Typo="Typography.Body" Style="font-weight: 600;">@context.TargetHostname</FluentLabel>
                    </FluentStack>
                </TemplateColumn>
                <TemplateColumn Title="Store Location">
                    <FluentLabel Typo="Typography.Body" Style="font-family: monospace; opacity: 0.7; font-size: 0.85rem;">@context.StoreLocation</FluentLabel>
                </TemplateColumn>
                <TemplateColumn Title="Certificate">
                    <FluentLabel Typo="Typography.Body" Style="font-family: monospace; font-size: 0.85rem;">@context.CertificateId.ToString()[..8]…</FluentLabel>
                </TemplateColumn>
                <TemplateColumn Title="Status">
                    <FluentBadge Appearance="@GetStatusAppearance(context.Status)" BackgroundColor="@GetStatusColor(context.Status)">@context.Status</FluentBadge>
                </TemplateColumn>
                <TemplateColumn Title="Details">
                    @if (!string.IsNullOrEmpty(context.ErrorMessage))
                    {
                        <FluentLabel Typo="Typography.Body" Style="color: var(--error);" Title="@context.ErrorMessage">Error</FluentLabel>
                    }
                    else if (context.CompletedAt.HasValue)
                    {
                        <FluentLabel Typo="Typography.Body" Style="color: var(--success);">@context.CompletedAt.Value.ToString("HH:mm:ss")</FluentLabel>
                    }
                    else
                    {
                        <FluentLabel Typo="Typography.Body" Style="opacity: 0.4;">—</FluentLabel>
                    }
                </TemplateColumn>
            </FluentDataGrid>
        }
    </FluentCard>
</FluentStack>

@code {
    private List<DeploymentJob>? jobs;

    protected override async Task OnInitializedAsync()
    {
        await RefreshJobs();
    }

    private async Task RefreshJobs()
    {
        try
        {
            jobs = await ApiClient.GetDeploymentJobsAsync();
        }
        catch (Exception)
        {
            jobs = new List<DeploymentJob>
            {
                new DeploymentJob { CreatedAt = DateTime.UtcNow.AddHours(-2), TargetHostname = "WIN-IIS-PROD-02", StoreLocation = "My/LocalMachine", CertificateId = Guid.NewGuid(), Status = "Completed", CompletedAt = DateTime.UtcNow.AddHours(-1).AddMinutes(-55) },
                new DeploymentJob { CreatedAt = DateTime.UtcNow.AddMinutes(-15), TargetHostname = "K8S-WORKER-07", StoreLocation = "/etc/pki/tls/certs/", CertificateId = Guid.NewGuid(), Status = "InProgress" },
                new DeploymentJob { CreatedAt = DateTime.UtcNow.AddHours(-3), TargetHostname = "WIN-IIS-PROD-02", StoreLocation = "My/LocalMachine", CertificateId = Guid.NewGuid(), Status = "Failed", ErrorMessage = "Access denied to Certificate Store. Insufficient permissions." },
                new DeploymentJob { CreatedAt = DateTime.UtcNow.AddMinutes(-5), TargetHostname = "K8S-WORKER-07", StoreLocation = "/var/lib/postgresql/certs/", CertificateId = Guid.NewGuid(), Status = "Pending" },
                new DeploymentJob { CreatedAt = DateTime.UtcNow.AddHours(-5), TargetHostname = "F5-LB-EDGE-01", StoreLocation = "clientssl/api-gateway", CertificateId = Guid.NewGuid(), Status = "Completed", CompletedAt = DateTime.UtcNow.AddHours(-4).AddMinutes(-50) }
            };
        }
    }

    private Appearance GetStatusAppearance(string status) => Appearance.Accent;

    private string GetStatusColor(string status) => status switch
    {
        "Completed" => "var(--success)",
        "InProgress" => "var(--accent-fill-rest)",
        "Failed" => "var(--error)",
        "Pending" => "var(--warning)",
        _ => ""
    };
}
}
