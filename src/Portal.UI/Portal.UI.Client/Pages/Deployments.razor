@page "/deployments"
@using Portal.UI.Client.Services
@using EnterprisePKI.Shared.Models
@inject PkiApiClient ApiClient
@rendermode InteractiveAuto

<PageTitle>Deployment Center</PageTitle>

<RadzenStack Gap="1rem" Style="width: 100%;">
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Style="width: 100%;">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
            <RadzenIcon Icon="rocket_launch" Style="color: var(--rz-warning);" />
            <RadzenText TextStyle="TextStyle.H4" Style="margin: 0;">Deployment Center</RadzenText>
        </RadzenStack>
        <RadzenButton Text="Refresh" Icon="sync" ButtonStyle="ButtonStyle.Secondary" Click="@RefreshJobs" />
    </RadzenStack>

    <!-- Stats Row -->
    @if (jobs != null)
    {
        <RadzenRow Gap="1rem">
            <RadzenColumn SizeSM="6" SizeMD="3">
                <RadzenCard Style="padding: 1rem;">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.625rem">
                        <RadzenIcon Icon="check_circle" Style="color: var(--rz-success);" />
                        <RadzenStack Gap="0.125rem">
                            <RadzenText TextStyle="TextStyle.Overline" Style="opacity: 0.7; margin: 0;">Completed</RadzenText>
                            <RadzenText TextStyle="TextStyle.H6" Style="font-weight: 700; margin: 0;">@jobs.Count(j => j.Status == "Completed")</RadzenText>
                        </RadzenStack>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn SizeSM="6" SizeMD="3">
                <RadzenCard Style="padding: 1rem;">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.625rem">
                        <RadzenIcon Icon="sync" Style="color: var(--rz-primary);" />
                        <RadzenStack Gap="0.125rem">
                            <RadzenText TextStyle="TextStyle.Overline" Style="opacity: 0.7; margin: 0;">In Progress</RadzenText>
                            <RadzenText TextStyle="TextStyle.H6" Style="font-weight: 700; margin: 0;">@jobs.Count(j => j.Status == "InProgress")</RadzenText>
                        </RadzenStack>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn SizeSM="6" SizeMD="3">
                <RadzenCard Style="padding: 1rem;">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.625rem">
                        <RadzenIcon Icon="schedule" Style="color: var(--rz-warning);" />
                        <RadzenStack Gap="0.125rem">
                            <RadzenText TextStyle="TextStyle.Overline" Style="opacity: 0.7; margin: 0;">Pending</RadzenText>
                            <RadzenText TextStyle="TextStyle.H6" Style="font-weight: 700; margin: 0;">@jobs.Count(j => j.Status == "Pending")</RadzenText>
                        </RadzenStack>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn SizeSM="6" SizeMD="3">
                <RadzenCard Style="padding: 1rem;">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.625rem">
                        <RadzenIcon Icon="cancel" Style="color: var(--rz-danger);" />
                        <RadzenStack Gap="0.125rem">
                            <RadzenText TextStyle="TextStyle.Overline" Style="opacity: 0.7; margin: 0;">Failed</RadzenText>
                            <RadzenText TextStyle="TextStyle.H6" Style="font-weight: 700; margin: 0;">@jobs.Count(j => j.Status == "Failed")</RadzenText>
                        </RadzenStack>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
        </RadzenRow>
    }

    <RadzenCard Style="padding: 0;">
        <div style="padding: 1rem;">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenIcon Icon="assignment" Style="color: var(--rz-warning);" />
                <RadzenText TextStyle="TextStyle.H6" Style="font-weight: 600; margin: 0;">Deployment Jobs</RadzenText>
            </RadzenStack>
        </div>

        @if (jobs == null)
        {
            <div style="padding: 2rem; text-align: center;">
                <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
            </div>
        }
        else if (!jobs.Any())
        {
            <div style="padding: 3rem; text-align: center;">
                <RadzenIcon Icon="rocket_launch" />
                <RadzenText TextStyle="TextStyle.Body1" Style="display: block; margin-top: 1rem; opacity: 0.6;">No deployment jobs found.</RadzenText>
            </div>
        }
        else
        {
            <RadzenDataGrid Data="@jobs" TItem="DeploymentJob" AllowSorting="true" Style="width: 100%;">
                <Columns>
                    <RadzenDataGridColumn TItem="DeploymentJob" Title="Created" Width="130px">
                        <Template Context="job">
                            <RadzenStack Gap="0.125rem">
                                <span>@job.CreatedAt.ToString("yyyy-MM-dd")</span>
                                <span style="opacity: 0.5; font-size: 0.8rem;">@job.CreatedAt.ToString("HH:mm:ss")</span>
                            </RadzenStack>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="DeploymentJob" Title="Target Host" Width="160px">
                        <Template Context="job">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                <RadzenIcon Icon="computer" Style="font-size: 1rem;" />
                                <span style="font-weight: 600;">@job.TargetHostname</span>
                            </RadzenStack>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="DeploymentJob" Title="Store Location" Width="160px">
                        <Template Context="job">
                            <span style="font-family: monospace; opacity: 0.7; font-size: 0.85rem;">@job.StoreLocation</span>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="DeploymentJob" Title="Certificate" Width="120px">
                        <Template Context="job">
                            <span style="font-family: monospace; font-size: 0.85rem;">@job.CertificateId.ToString()[..8]…</span>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="DeploymentJob" Title="Status" Width="110px">
                        <Template Context="job">
                            <RadzenBadge Text="@job.Status" BadgeStyle="@GetStatusBadgeStyle(job.Status)" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="DeploymentJob" Title="Details" Width="130px">
                        <Template Context="job">
                            @if (!string.IsNullOrEmpty(job.ErrorMessage))
                            {
                                <span style="color: var(--rz-danger);" title="@job.ErrorMessage">Error</span>
                            }
                            else if (job.CompletedAt.HasValue)
                            {
                                <span style="color: var(--rz-success);">@job.CompletedAt.Value.ToString("HH:mm:ss")</span>
                            }
                            else
                            {
                                <span style="opacity: 0.4;">—</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        }
    </RadzenCard>
</RadzenStack>

@code {
    private List<DeploymentJob>? jobs;

    protected override async Task OnInitializedAsync()
    {
        await RefreshJobs();
    }

    private async Task RefreshJobs()
    {
        try
        {
            jobs = await ApiClient.GetDeploymentJobsAsync();
        }
        catch (Exception)
        {
            jobs = new List<DeploymentJob>
            {
                new DeploymentJob { CreatedAt = DateTime.UtcNow.AddHours(-2), TargetHostname = "WIN-IIS-PROD-02", StoreLocation = "My/LocalMachine", CertificateId = Guid.NewGuid(), Status = "Completed", CompletedAt = DateTime.UtcNow.AddHours(-1).AddMinutes(-55) },
                new DeploymentJob { CreatedAt = DateTime.UtcNow.AddMinutes(-15), TargetHostname = "K8S-WORKER-07", StoreLocation = "/etc/pki/tls/certs/", CertificateId = Guid.NewGuid(), Status = "InProgress" },
                new DeploymentJob { CreatedAt = DateTime.UtcNow.AddHours(-3), TargetHostname = "WIN-IIS-PROD-02", StoreLocation = "My/LocalMachine", CertificateId = Guid.NewGuid(), Status = "Failed", ErrorMessage = "Access denied to Certificate Store. Insufficient permissions." },
                new DeploymentJob { CreatedAt = DateTime.UtcNow.AddMinutes(-5), TargetHostname = "K8S-WORKER-07", StoreLocation = "/var/lib/postgresql/certs/", CertificateId = Guid.NewGuid(), Status = "Pending" },
                new DeploymentJob { CreatedAt = DateTime.UtcNow.AddHours(-5), TargetHostname = "F5-LB-EDGE-01", StoreLocation = "clientssl/api-gateway", CertificateId = Guid.NewGuid(), Status = "Completed", CompletedAt = DateTime.UtcNow.AddHours(-4).AddMinutes(-50) }
            };
        }
    }

    private BadgeStyle GetStatusBadgeStyle(string status) => status switch
    {
        "Completed" => BadgeStyle.Success,
        "InProgress" => BadgeStyle.Info,
        "Failed" => BadgeStyle.Danger,
        "Pending" => BadgeStyle.Warning,
        _ => BadgeStyle.Light
    };
}
