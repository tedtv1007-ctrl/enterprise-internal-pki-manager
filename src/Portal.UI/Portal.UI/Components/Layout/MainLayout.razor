@inherits LayoutComponentBase

<FluentLayout>
    <FluentHeader Height="50">
        <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" VerticalAlignment="VerticalAlignment.Center" Width="100%">
            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="8">
                <FluentIcon Value="@(new Icons.Regular.Size24.ShieldKeyhole())" Color="Color.Accent" />
                <FluentLabel Typo="Typography.Subject" Style="font-weight: 600;">PKI Manager</FluentLabel>
            </FluentStack>
            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="12">
                <FluentBadge Appearance="Appearance.Accent">Systems Online</FluentBadge>
                <FluentBadge Appearance="Appearance.Lightweight">PQC Ready</FluentBadge>
                <FluentLabel Typo="Typography.Body" Style="opacity: 0.6;">v2.0.0</FluentLabel>
            </FluentStack>
        </FluentStack>
    </FluentHeader>

    <FluentStack Orientation="Orientation.Horizontal" Width="100%" Style="height: calc(100vh - 50px);">
        <NavMenu />
        <FluentBodyContent>
            <div style="padding: 1.5rem;">
                @Body
            </div>
        </FluentBodyContent>
    </FluentStack>
</FluentLayout>

<FluentToastProvider />
<FluentDialogProvider />
<FluentMessageBarProvider />
<FluentTooltipProvider />

<FluentDesignTheme Mode="DesignThemeModes.Dark"
                   OfficeColor="OfficeColor.Teams"
                   StorageName="pki-theme" />

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
